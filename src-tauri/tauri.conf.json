{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "JF Goat",
  "version": "1.4.0",
  "identifier": "com.jfgoat.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node ./scripts/before-bundle.cjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JF Goat",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' jfimage: http: https:; connect-src 'self' ipc: http: https:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./capabilities/entitlements.plist"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "./scripts/sign-windows.ps1",
          "%1"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bin/mpv-2.dll": "mpv-2.dll"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/MartinIndra02/jfFast/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxMTc1QThFRTRCODM5MkYKUldRdk9iamtqbG9YWVYyVlQ5L0ltK1ArTisxcmZycnhqUkwxNlZIQXJuZDJzeTdlcGV4Z0g5NzYK"
    }
  }
}
