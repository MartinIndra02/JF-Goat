{
  "name": "jfgoat",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "test:baseline:web": "npm run test:unit && npm run test:e2e:smoke && npm run build",
    "test:baseline:full": "npm run test:rust && npm run test:baseline:web",
    "test:baseline": "npm run test:baseline:web",
    "ci:frontend": "npm run test:baseline:web",
    "ci:gate": "npm run test:baseline:web",
    "release:tauri": "npm run tauri build"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "jsdom": "^26.1.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-stronghold": "^2",
    "svelte-spa-router": "^4.0.1"
  }
}
